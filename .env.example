# ============================================
# Configuration environnement TESSIPI Foundation
# ============================================
# Copier ce fichier en .env et modifier les valeurs

# Base de données
DB_HOST=localhost
DB_NAME=tessipi_foundation
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Configuration email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@tessipi.org
SMTP_FROM_NAME=TESSIPI Foundation

# API Keys
STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here

# Sécurité
JWT_SECRET=your-secret-key-here-change-in-production
SESSION_LIFETIME=3600

# Environnement
ENVIRONMENT=development
DEBUG=true

# URL du site
SITE_URL=http://localhost/tessipi-foundation
API_URL=http://localhost/tessipi-foundation/backend/api
